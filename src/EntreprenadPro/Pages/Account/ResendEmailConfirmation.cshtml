@page
@model ResendEmailConfirmationModel
@{
  ViewData["Title"] = "Skicka verifikation igen";
}

<h1>@ViewData["Title"]</h1>
<hr/>
<form method="post">
  <div class="form-group">
    <label asp-for="Input.Email"></label>
    <input asp-for="Input.Email" aria-required="true" placeholder="name@example.com"/>
    <span asp-validation-for="Input.Email"></span>
  </div>
  <button>Skicka igen</button>
</form>

