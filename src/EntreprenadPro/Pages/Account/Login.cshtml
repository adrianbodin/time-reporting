@page
@model LoginModel

<section class="wrapper">
  <form id="account" method="post">
    <h1 class="text-2xl">Logga in</h1>
    <hr />
    <div class="form-group">
      <label asp-for="Input.Email">E-post</label>
      <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="namn@exempel.se"/>
      <span asp-validation-for="Input.Email"></span>
    </div>
    <div class="form-group">
      <label asp-for="Input.Password">Lösenord</label>
      <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="lösenord"/>
      <span asp-validation-for="Input.Password"></span>
    </div>
    <div class="form-group">
      <input asp-for="Input.RememberMe" />
      <label asp-for="Input.RememberMe">Kom ihåg mig</label>
    </div>
    <button type="submit" data-testid="submit-button">Logga in</button>
  </form>
</section>