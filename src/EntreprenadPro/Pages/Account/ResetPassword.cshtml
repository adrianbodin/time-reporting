@page
@model ResetPasswordModel
@{
  ViewData["Title"] = "Byt lösenord";
}

<h1>@ViewData["Title"]</h1>
<hr/>
<form method="post">
  <input asp-for="Input.Code" type="hidden"/>
  <div class="form-group">
    <label asp-for="Input.Email"></label>
    <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com"/>
    <span asp-validation-for="Input.Email"></span>
  </div>
  <div class="form-group">
    <label asp-for="Input.Password"></label>
    <input asp-for="Input.Password" autocomplete="new-password" aria-required="true" placeholder="Admin123!"/>
    <span asp-validation-for="Input.Password"></span>
  </div>
  <div class="form-group">
    <label asp-for="Input.ConfirmPassword"></label>
    <input asp-for="Input.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="Admin123!"/>
    <span asp-validation-for="Input.ConfirmPassword"></span>
  </div>
  <button>Byt</button>
</form>