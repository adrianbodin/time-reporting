@page
@using EntreprenadPro.Helpers
@model EntreprenadPro.Pages.Tid.Skapa

<section>
  <hr>
  <form method="post" up-target=".entries" class="add-entry-form" up-submit>
    <div class="mb-3">
      <label asp-for="NewEntry.TimeEntryType" class="form-label mb-0">Typ av tid</label>
      <select asp-for="NewEntry.TimeEntryType" class="form-select form-select-lg" up-switch=".type-dependant"
              asp-items="@EnumHelper.GetSelectList<TimeEntryType>()">
      </select>
    </div>

    <div class="mb-3 type-dependant" up-show-for="@TimeEntryType.Debitable">
      <label asp-for="NewEntry.ProjectId" class="form-label mb-0">Projekt</label>
      <div class="mb-3 input-group">
        <select asp-for="NewEntry.ProjectId" class="form-select form-select-lg project-selection">
          <option value="">Välj ett projekt</option>
          @foreach (var project in Model.Projects)
          {
            <option value="@project.Id">@project.Name</option>
          }
        </select>
        <a
          class="btn btn-outline-secondary rounded-end d-flex justify-content-center align-items-center"
          href="/Projekt/Skapa"
          up-layer="new modal"
          up-history="false"
          up-accept-location="/Projekt"
          up-on-accepted="up.reload('.project-selection')">
          Ny
        </a>
      </div>
      <span class="text-danger" asp-validation-for="NewEntry.ProjectId"></span>
    </div>
    <div class="row mb-3">
      <div class="col-4">
        <label asp-for="NewEntry.Hours" class="form-label mb-0">Antal timmar</label>
        <input type="number" min="0" step="0.5" value="8" asp-for="NewEntry.Hours"
               class="form-control form-control-lg"/>
        <span class="text-danger" asp-validation-for="NewEntry.Hours"></span>
      </div>
      <div class="col-8 type-dependant" up-show-for="@TimeEntryType.Debitable @TimeEntryType.Internal">
        <label asp-for="NewEntry.WorkTypeId" class="form-label mb-0">Work type</label>
        <select asp-for="NewEntry.WorkTypeId" class="form-select form-select-lg work-type-selection">
          <option value="">Välj en arbetstyp</option>
          >
          @foreach (var workType in Model.WorkTypes)
          {
            <option value="@workType.Id">@workType.Name</option>
          }
        </select>
      </div>
    </div>
    <div class="mb-3">
      <label asp-for="NewEntry.Date" class="form-label mb-0">Datum</label>
      <input asp-for="NewEntry.Date" class="form-control form-control-lg"/>
      <span class="text-danger" asp-validation-for="NewEntry.Date"></span>
    </div>
    <div class="mb-3">
      <label asp-for="NewEntry.Description" class="form-label mb-0">Beskrivning</label>
      <textarea asp-for="NewEntry.Description" rows="7" cols="100" class="form-control form-control-lg"></textarea>
      <span class="text-danger" asp-validation-for="NewEntry.Description"></span>
    </div>
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-primary btn-lg w-100">Lägg till</button>
  </form>
</section>